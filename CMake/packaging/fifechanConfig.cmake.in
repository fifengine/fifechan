@PACKAGE_INIT@

set(PACKAGE_NAME    "fifechan")
set(PACKAGE_VERSION "@PROJECT_VERSION@")

# Set Install Directories
set(PACKAGE_INSTALL_DIR       "${CMAKE_INSTALL_PREFIX}")
set(PACKAGE_INCLUDE_DIR       "${PACKAGE_INSTALL_DIR}/include")
set(PACKAGE_LIBRARY_DIR       "${PACKAGE_INSTALL_DIR}/lib")
set(PACKAGE_CMAKE_MODULE_DIR  "${PACKAGE_INSTALL_DIR}/cmake")

# Export the package configuration
configure_file(
    "${CMAKE_CURRENT_LIST_DIR}/fifechanConfig.cmake.in"
    "${CMAKE_CURRENT_BINARY_DIR}/fifechanConfig.cmake" @ONLY)

# Install the package configuration
install(FILES "${CMAKE_CURRENT_BINARY_DIR}/fifechanConfig.cmake" DESTINATION "${PACKAGE_CMAKE_MODULE_DIR}")
